Vagrant.configure("2") do |config|
  # Use VirtualBox as the virtualization provider for Windows environment
  config.vm.provider "virtualbox"

  # 1. WEB SERVER CONFIGURATION (Ubuntu Bionic 18.04)

  config.vm.define "web" do |web|
    web.vm.box = "ubuntu/bionic64"
    web.vm.hostname = "web-server"
    
    # Configure private network IP for internal communication
    web.vm.network "private_network", ip: "192.168.33.11"
    
    # Forward host port 8080 to guest port 80 for HTTP web traffic
    web.vm.network "forwarded_port", guest: 80, host: 8080, id: "http", auto_correct: true
    # Forward host port 2222 to guest port 22 for SSH access
    web.vm.network "forwarded_port", guest: 22, host: 2222, id: "ssh", auto_correct: true

    # Provisioning script to install and configure Web services
    web.vm.provision "shell", inline: <<-SHELL
      export DEBIAN_FRONTEND=noninteractive
      apt-get update
      # Install Nginx web server, MySQL client for DB queries, and Prometheus Node Exporter
      apt-get install -y nginx mysql-client prometheus-node-exporter
      
      # Serve the required static HTML content
      echo "<h1>Welcome to the Web Server!</h1>" > /var/www/html/index.html
      systemctl restart nginx

      # Create an automated script to test DB connection and query the users table
      cat << 'EOF' > /home/vagrant/db_test.sh
#!/bin/bash
# Query the DB server over the private network and log the output to the required file path
mysql -h 192.168.33.12 -u webuser -pwebpass test_db -e "SELECT * FROM users;" > /var/log/db_query.log
cat /var/log/db_query.log
EOF
      # Grant execution permissions and assign ownership of the script to vagrant user
      chmod +x /home/vagrant/db_test.sh
      chown vagrant:vagrant /home/vagrant/db_test.sh
      
      # Execute the script during setup to generate the initial log file
      /home/vagrant/db_test.sh
    SHELL
  end


  # 2. DATABASE SERVER CONFIGURATION (Ubuntu Focal 20.04)

  config.vm.define "db" do |db|
    db.vm.box = "ubuntu/focal64"
    db.vm.hostname = "db-server"
    
    # Configure private network IP for internal communication
    db.vm.network "private_network", ip: "192.168.33.12"
    # Forward host port 3333 to guest port 22 for SSH access
    db.vm.network "forwarded_port", guest: 22, host: 3333, id: "ssh", auto_correct: true

    # Provisioning script to install and configure MySQL Database
    db.vm.provision "shell", inline: <<-SHELL
      # Definition of environment variables for database credentials
      export DB_USER="webuser"
      export DB_PASS="webpass"
      export DB_NAME="test_db"
      export DEBIAN_FRONTEND=noninteractive
      
      # Permanently save environment variables to the system profile
      echo "export DB_USER='${DB_USER}'" >> /etc/profile
      echo "export DB_PASS='${DB_PASS}'" >> /etc/profile

      apt-get update
      # Install MySQL Server and Prometheus Node Exporter for metrics collection
      apt-get install -y mysql-server prometheus-node-exporter
      
      # Configure MySQL to listen on all interfaces so the web server can connect via private network
      sed -i 's/bind-address.*/bind-address = 0.0.0.0/' /etc/mysql/mysql.conf.d/mysqld.cnf
      systemctl restart mysql
      
      # Initialize database layout, create user using env variables, and assign network privileges
      mysql -e "CREATE DATABASE IF NOT EXISTS ${DB_NAME};"
      mysql -e "CREATE USER IF NOT EXISTS '${DB_USER}'@'%' IDENTIFIED BY '${DB_PASS}';"
      mysql -e "GRANT ALL PRIVILEGES ON ${DB_NAME}.* TO '${DB_USER}'@'%';"
      mysql -e "FLUSH PRIVILEGES;"
      
      # Create sample users table and populate it with required database entries
      mysql ${DB_NAME} -e "CREATE TABLE IF NOT EXISTS users (id INT, name VARCHAR(50));"
      mysql ${DB_NAME} -e "TRUNCATE TABLE users; INSERT INTO users (id, name) VALUES (1, 'Alice'), (2, 'Bob');"
    SHELL
  end


  # 3. MONITORING SERVER CONFIGURATION (Ubuntu Bionic 18.04)

  config.vm.define "monitoring" do |mon|
    mon.vm.box = "ubuntu/bionic64"
    mon.vm.hostname = "monitoring-server"
    
    # Configure private network IP for internal communication
    mon.vm.network "private_network", ip: "192.168.33.13"
    # Forward host port 4444 to guest port 22 for SSH access
    mon.vm.network "forwarded_port", guest: 22, host: 4444, id: "ssh", auto_correct: true
    # Forward host port 9090 to guest port 9090 to access Prometheus dashboard via browser
    mon.vm.network "forwarded_port", guest: 9090, host: 9090, auto_correct: true

    # Provisioning script to install and configure Prometheus Monitoring engine
    mon.vm.provision "shell", inline: <<-SHELL
      export DEBIAN_FRONTEND=noninteractive
      apt-get update
      # Install Prometheus package from default repositories
      apt-get install -y prometheus
      
      # Generate prometheus.yml config file to scrape metrics via private network Node Exporters (port 9100)
      cat << 'EOF' > /etc/prometheus/prometheus.yml
global:
  scrape_interval: 15s
scrape_configs:
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']
  - job_name: 'web_server_metrics'
    static_configs:
      - targets: ['192.168.33.11:9100']
  - job_name: 'db_server_metrics'
    static_configs:
      - targets: ['192.168.33.12:9100']
EOF
      systemctl restart prometheus
    SHELL
  end
end